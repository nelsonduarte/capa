{
    "comments": {
        "lineComment": "//"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<", ">"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string"] },
        { "open": "'", "close": "'", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*((\\b(fun|if|elif|else|while|for|match|type|trait|impl|capability)\\b.*)|->.*\\)\\s*$|=>\\s*$)",
        "decreaseIndentPattern": "^\\s*$"
    },
    "wordPattern": "(-?\\d+\\.\\d\\w*)|([a-zA-Z_][a-zA-Z0-9_]*)"
}
